# Auth Service — Environment Variables
# Copy to .env and fill in real values

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (Write) ─────────────────────────────────────────────────────────
# Real server via WireGuard:
AUTH_DATABASE_URL="postgresql://livefxhubv3:Livefxhub@123@10.10.0.1:30432/auth_db"
# Local Docker dev:
# AUTH_DATABASE_URL="postgresql://lfx:lfx_dev_secret@localhost:5432/auth_db"

# ─── Database (Read Replica) ─────────────────────────────────────────────────
AUTH_DATABASE_URL_READ="postgresql://livefxhubv3:Livefxhub@123@10.10.0.1:30433/auth_db"
# Local Docker dev (no replica — point to same DB):
# AUTH_DATABASE_URL_READ="postgresql://lfx:lfx_dev_secret@localhost:5432/auth_db"

# ─── Redis Cluster ───────────────────────────────────────────────────────────
# Real server cluster (ioredis auto-discovers all 6 nodes from seed):
REDIS_CLUSTER_NODES="10.10.0.3:31001"
# Local Docker dev (single node — treated as standalone):
# REDIS_CLUSTER_NODES="127.0.0.1:6379"

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=auth-service

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_256bit_random_secret_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── TOTP 2FA Encryption ─────────────────────────────────────────────────────
TOTP_ENCRYPTION_KEY=replace_with_256bit_aes_key_minimum_32_chars

# ─── Trusted Device ──────────────────────────────────────────────────────────
TRUSTED_DEVICE_DAYS=30

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
