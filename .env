# auth-service — Local Development .env
# DO NOT COMMIT THIS FILE TO GIT

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── Database (Write — real server via WireGuard) ────────────────────────────
AUTH_DATABASE_URL="postgresql://livefxhubv3:Livefxhub@123@10.10.0.1:30432/auth_db?sslmode=disable"

# ─── Database (Read Replica) ─────────────────────────────────────────────────
AUTH_DATABASE_URL_READ="postgresql://livefxhubv3:Livefxhub@123@10.10.0.1:30433/auth_db?sslmode=disable"

# ─── Redis ───────────────────────────────────────────────────────────────────
# VPN cluster: all 6 nodes (3 masters + 3 replicas) via 185.131.54.146
# For local-only dev (no VPN): use "127.0.0.1:6379"
REDIS_CLUSTER_NODES="185.131.54.146:31010,185.131.54.146:31011,185.131.54.146:31003,185.131.54.146:31009,185.131.54.146:31007,185.131.54.146:31008"

# NAT map: Redis advertises internal IPs in CLUSTER NODES gossip.
# ioredis uses this map to rewrite internal → external before connecting.
REDIS_NAT_MAP='{"10.50.0.184:6379":{"host":"185.131.54.146","port":31010},"10.50.0.186:6379":{"host":"185.131.54.146","port":31011},"10.50.0.188:6379":{"host":"185.131.54.146","port":31003},"10.50.0.190:6379":{"host":"185.131.54.146","port":31009},"10.50.0.192:6379":{"host":"185.131.54.146","port":31007},"10.50.0.194:6379":{"host":"185.131.54.146","port":31008}}'

# ─── Kafka (local Docker) ────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=auth-service

# ─── JWT ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a real 32+ char random secret before production
JWT_SECRET=lfx_v3_dev_jwt_secret_change_in_production_2025
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── TOTP 2FA — AES-256 Encryption Key ──────────────────────────────────────
# IMPORTANT: Must be exactly 32 chars. Change before production.
TOTP_ENCRYPTION_KEY=6c66787633746f74706b657930313233343536373839616263646566303132333435

# ─── Trusted Device ──────────────────────────────────────────────────────────
TRUSTED_DEVICE_DAYS=30

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Email (Hostinger SMTP) ──────────────────────────────────────────────────
EMAIL_HOST=mail.livefxhub.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=noreply@livefxhub.com
EMAIL_PASS=Lkj@asd@123
EMAIL_FROM=noreply@livefxhub.com

# ─── 2FA / Device Trust ──────────────────────────────────────────────────────
AUTH_INACTIVITY_2FA_DAYS=30
AUTH_NEW_DEVICE_ALERT=true

# ─── Internal Service Communication ──────────────────────────────────────────
INTERNAL_SERVICE_SECRET=lfx_v3_internal_secret_change_in_production
USER_SERVICE_INTERNAL_URL=http://localhost:3002
ADMIN_SERVICE_INTERNAL_URL=http://localhost:3004
